# Database — SQLite for local dev, PostgreSQL (Supabase) for production
# Local dev (default — no config needed):
#   sqlite+aiosqlite:///./amplifier.db
# Supabase PostgreSQL (set on Vercel):
#   postgresql+asyncpg://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/amplifier

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Stripe (Phase D launch)
# ==========================================================================
# LAUNCH SCOPE 2026-05-02: Amplifier ships v1.0.0 with DEMO Stripe sandbox
# keys (Stock Buddy sandbox account acct_1TCGfuABBUrjm7YF). This is NOT safe
# for real users and money — sandbox transfers do not move real funds.
#
# BEFORE opening to public users:
#   1. Replace STRIPE_SECRET_KEY below with a LIVE secret key (sk_live_...)
#      from the production Stripe account (father's company, per
#      project_stripe_account.md memory).
#   2. Replace STRIPE_WEBHOOK_SECRET with the LIVE webhook signing secret.
#   3. Test end-to-end with a $1 real Stripe Connect transfer to a verified
#      bank account before launch announcement.
#   4. Update VPS systemd unit:
#      sudo systemctl edit amplifier-web.service
#      (set Environment=STRIPE_SECRET_KEY=sk_live_...)
#      sudo systemctl daemon-reload && sudo systemctl restart amplifier-web.service
#
# Tracked as Task #19. Pre-launch checklist in
# docs/migrations/2026-05-01-migration-gap-audit.md.
# ==========================================================================
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Platform cut percentage (0-100)
PLATFORM_CUT_PERCENT=20

# Minimum payout threshold (USD)
MIN_PAYOUT_THRESHOLD=10.00

# Admin dashboard password
ADMIN_PASSWORD=admin

# Supabase Storage (for campaign image/file uploads)
# Get these from Supabase Dashboard → Settings → API
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_KEY=eyJ...

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true
