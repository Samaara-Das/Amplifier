# Auto-Poster Configuration — copy to config/.env and fill in your values
AUTO_POSTER_ROOT=/path/to/Auto-Posting-System
LOG_LEVEL=INFO
GENERATE_COUNT=6

# Amplifier Server URL (deployed server — override for local dev: http://localhost:8000)
CAMPAIGN_SERVER_URL=https://api.pointcapitalis.com

# Content Generation API Keys (free tiers)
# GEMINI_API_KEY — Required for text, free at https://ai.google.dev
GEMINI_API_KEY=
# MISTRAL_API_KEY — Optional, free at https://console.mistral.ai
MISTRAL_API_KEY=
# GROQ_API_KEY — Optional, free at https://console.groq.com
GROQ_API_KEY=

# Image Generation API Keys (free tiers — need at least one for AI-generated images)
# CLOUDFLARE_ACCOUNT_ID — Free at https://dash.cloudflare.com (Account ID on overview page)
CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_API_TOKEN — Create at https://dash.cloudflare.com/profile/api-tokens (use "Workers AI" template)
CLOUDFLARE_API_TOKEN=
# TOGETHER_API_KEY — Free at https://api.together.ai (FLUX image gen, no credit card)
TOGETHER_API_KEY=

# Metric Collection API Keys (optional — falls back to Playwright scraping)
X_BEARER_TOKEN=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Posting behavior
POST_INTERVAL_MIN_SEC=30
POST_INTERVAL_MAX_SEC=90
PAGE_LOAD_TIMEOUT_SEC=30
COMPOSE_FIND_TIMEOUT_SEC=15

# Browsing behavior (human emulation)
BROWSE_MIN_DURATION_SEC=60
BROWSE_MAX_DURATION_SEC=300
BROWSE_POSTS_TO_VIEW_MIN=2
BROWSE_POSTS_TO_VIEW_MAX=4
BROWSE_PROFILES_TO_CLICK_MIN=1
BROWSE_PROFILES_TO_CLICK_MAX=2

# Browser mode (true for scheduled runs, false for manual testing)
HEADLESS=true

# CTA rotation
FIRST_POST_DATE=

# Auto-engagement daily caps
MAX_LIKES_X=15
MAX_RETWEETS_X=3
MAX_LIKES_LINKEDIN=8
MAX_REPOSTS_LINKEDIN=2

# ── UAT: test account credentials (required for uat-task skill) ──────────────
# These are NOT production credentials — use dedicated test accounts only.
UAT_TEST_USER_EMAIL=
UAT_TEST_USER_PASSWORD=
UAT_TEST_COMPANY_EMAIL=
UAT_TEST_COMPANY_PASSWORD=

# ── UAT: test-mode flags (uncomment to activate; do NOT leave enabled in prod) ─
# AMPLIFIER_UAT_INTERVAL_SEC=120  # content-gen loop interval + research/strategy cache TTL in seconds
# AMPLIFIER_UAT_BYPASS_AI=1       # force ContentAgent fallback path (exercises ContentGenerator.generate())
# AMPLIFIER_UAT_FORCE_DAY=5       # override day_number in generate_daily_content (tests diversity AC8)
# AMPLIFIER_UAT_POST_NOW=1        # schedule approved drafts ~1min out instead of next slot (AC17 fast loop)
