{
  "platform": "x",
  "action": "post",
  "version": "2026.04.03",
  "home_url": "https://x.com/home",
  "variables_required": ["text"],
  "steps": [
    {
      "id": "browse_feed",
      "type": "goto",
      "url": "https://x.com/home",
      "wait_for": { "selector": "[data-testid='primaryColumn']", "timeout_ms": 15000 },
      "description": "Navigate to home feed"
    },
    {
      "id": "pre_browse",
      "type": "browse_feed",
      "timeout_ms": 2000,
      "description": "Simulate brief feed browsing"
    },
    {
      "id": "open_compose",
      "type": "goto",
      "url": "https://x.com/compose/post",
      "wait_for": { "selector": "[role='textbox']", "timeout_ms": 15000 },
      "description": "Navigate to compose page"
    },
    {
      "id": "wait_compose",
      "type": "wait",
      "timeout_ms": 1500,
      "description": "Brief pause before interacting"
    },
    {
      "id": "upload_image",
      "type": "file_upload",
      "file_path": "{{image_path}}",
      "file_selector": "input[data-testid='fileInput']",
      "delay_before_ms": { "min": 500, "max": 1500 },
      "description": "Upload image via hidden file input (skipped if no image)"
    },
    {
      "id": "wait_image_attach",
      "type": "wait_and_verify",
      "success_signals": [
        { "selector": "[data-testid='attachments']" }
      ],
      "timeout_ms": 15000,
      "description": "Wait for image attachment preview"
    },
    {
      "id": "wait_image_process",
      "type": "wait",
      "timeout_ms": 3000,
      "description": "Extra wait for X to process image"
    },
    {
      "id": "focus_textbox",
      "type": "click",
      "target": {
        "strategy": "fallback_chain",
        "selectors": [
          { "by": "css", "value": "[role='textbox']" },
          { "by": "css", "value": "[data-testid='tweetTextarea_0']" }
        ]
      },
      "force": true,
      "delay_before_ms": { "min": 300, "max": 700 },
      "description": "Click textbox to focus (triggers React onFocus)"
    },
    {
      "id": "wait_focus",
      "type": "wait",
      "timeout_ms": 500
    },
    {
      "id": "type_text",
      "type": "text_input",
      "target": {
        "strategy": "fallback_chain",
        "selectors": [
          { "by": "css", "value": "[role='textbox']" },
          { "by": "css", "value": "[data-testid='tweetTextarea_0']" }
        ]
      },
      "text": "{{text}}",
      "typing_speed": { "min": 30, "max": 80 },
      "delay_after_ms": { "min": 1000, "max": 3000 },
      "description": "Type post content character by character"
    },
    {
      "id": "submit_post",
      "type": "keyboard",
      "key": "Control+Enter",
      "delay_before_ms": { "min": 500, "max": 1500 },
      "description": "Submit via Ctrl+Enter (bypasses overlay div that intercepts pointer events on tweet button)"
    },
    {
      "id": "wait_post_process",
      "type": "wait",
      "timeout_ms": 5000,
      "description": "Wait for post to process"
    },
    {
      "id": "screenshot_after",
      "type": "screenshot",
      "description": "Capture state after posting"
    },
    {
      "id": "close_compose_overlay",
      "type": "keyboard",
      "key": "Escape",
      "description": "Close compose overlay that intercepts pointer events"
    },
    {
      "id": "wait_overlay_close",
      "type": "wait",
      "timeout_ms": 2000
    },
    {
      "id": "extract_username",
      "type": "evaluate",
      "js_code": "() => { const link = document.querySelector('a[data-testid=\"AppTabBar_Profile_Link\"]'); return link ? link.getAttribute('href').replace('/', '') : ''; }",
      "description": "Extract username from profile sidebar link"
    },
    {
      "id": "go_to_profile",
      "type": "evaluate",
      "js_code": "(_, username) => { if (username) window.location.href = 'https://x.com/' + username; return username; }",
      "js_args": ["_result_extract_username"],
      "description": "Navigate to profile page via JS (avoids overlay click interception)"
    },
    {
      "id": "wait_profile_load",
      "type": "wait",
      "timeout_ms": 5000
    },
    {
      "id": "extract_post_url",
      "type": "extract_url",
      "target": {
        "strategy": "fallback_chain",
        "selectors": [
          { "by": "css", "value": "article[data-testid='tweet'] a[href*='/status/']" },
          { "by": "css", "value": "a[href*='/status/']" }
        ]
      },
      "timeout_ms": 10000,
      "description": "Extract URL of the newly posted tweet"
    },
    {
      "id": "post_browse",
      "type": "browse_feed",
      "timeout_ms": 2000,
      "description": "Post-post browsing"
    }
  ],
  "error_recovery": {
    "on_element_not_found": "retry_with_next_selector",
    "on_unexpected_screen": "navigate_back_and_retry",
    "on_popup": "dismiss_and_continue",
    "on_timeout": "retry",
    "max_retries": 3,
    "on_failure": "queue_for_manual"
  }
}
